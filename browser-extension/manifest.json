{
  "manifest_version": 3,
  "name": "Quaesitor",
  "version": "1.0.0",
  "description": "Capture pages and research with Quaesitor AI",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quaesitor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "quaesitor@z.ai",
      "strict_min_version": "115.0"
    }
  }
}
