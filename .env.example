# Deep Research Engine — Environment Configuration
#
# NVIDIA NIM is the ONLY external service. Everything else is free/open.
# DuckDuckGo for search (no key), direct fetch + Readability for pages.

# === NVIDIA NIM API ===
# Get your FREE key from: https://build.nvidia.com/
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# SMART_LLM — for analysis and report writing.
# Strongest models on NVIDIA NIM:
#   meta/llama-3.1-70b-instruct (recommended)
#   nvidia/llama-3.1-nemotron-70b-instruct
#   mistralai/mistral-large-3-675b-instruct-2512
SMART_LLM=meta/llama-3.1-70b-instruct

# FAST_LLM — for sub-questions and quick tasks.
FAST_LLM=meta/llama-3.1-8b-instruct

# SMART_LLM_MODELS — fallback chain (comma-separated).
# If the first fails, the next is tried.
SMART_LLM_MODELS=meta/llama-3.1-70b-instruct,mistralai/mistral-nemotron,mistralai/mistral-small-4-119b-2603,minimaxai/minimax-m3,deepseek-ai/deepseek-v4-pro,mistralai/mistral-large-3-675b-instruct-2512

# === Research Engine Settings ===
SEARCH_DEPTH=advanced
NUM_SUB_QUERIES=7
MAX_LINKS_PER_QUERY=15
NUM_GAP_QUERIES=3
PAGE_READ_CONCURRENCY=4
REPORT_MAX_TOKENS=8000

# === Auth (optional) ===
# Set both to enable HTTP Basic Auth.
AUTH_USERNAME=
AUTH_PASSWORD=

# === Database (optional — defaults to ./data/research.db) ===
# SQLite file path for session persistence (history). If omitted, the app
# uses ./data/research.db relative to the project root. Falls back to
# in-memory if the filesystem is read-only.
# DATABASE_URL=file:./data/research.db

# === Document Upload Limit ===
MAX_DOCUMENT_SIZE_MB=50
