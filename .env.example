# ============================================================
# Deep Research Engine - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
# ============================================================

# === NVIDIA NIM API ===
# Get your FREE key from: https://build.nvidia.com/
# (Required for the 6-model NVIDIA LLM fallback chain)
NVIDIA_API_KEY=

# NVIDIA NIM OpenAI-compatible endpoint
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# SMART_LLM_MODELS — Fallback chain of 6 powerful agent-capable models.
# Ordered for SPEED: fastest reliable model first, most powerful as fallback.
SMART_LLM_MODELS=meta/llama-3.1-70b-instruct,mistralai/mistral-nemotron,mistralai/mistral-small-4-119b-2603,minimaxai/minimax-m3,deepseek-ai/deepseek-v4-pro,mistralai/mistral-large-3-675b-instruct-2512

# Backward-compatible single-model setting
SMART_LLM=meta/llama-3.1-70b-instruct

# FAST_LLM - For generating sub-questions quickly and cheaply.
FAST_LLM=meta/llama-3.1-8b-instruct

# LLM_PROVIDER: "zai" (free, built-in) | "nvidia" (uses NVIDIA_API_KEY)
# NOTE: if set to "nvidia" but NVIDIA_API_KEY is empty, the engine auto-falls
# back to "zai". The template default is "nvidia" assuming you filled the key above.
LLM_PROVIDER=nvidia

# === Research Engine Settings ===

# Search depth: "standard" | "deep" | "advanced"
# - standard: 3 sub-queries × 4 links = 12 pages, single round   (~2-3 min)
# - deep:     5 sub-queries × 8 links = 40 pages, multi-round     (~5-7 min)
# - advanced: 7 sub-queries × 15 links = 105 pages, multi-round   (~10-15 min)
SEARCH_DEPTH=advanced

# Number of sub-questions to generate (for "advanced" depth)
# Range: 2-12.
NUM_SUB_QUERIES=7

# Max links to read per sub-question.
MAX_LINKS_PER_QUERY=15

# Number of gap-filling sub-questions for round 2 (multi-round research).
NUM_GAP_QUERIES=3

# Concurrency for page reading (pages fetched in parallel per sub-query)
PAGE_READ_CONCURRENCY=6

# Max tokens for the final comprehensive long-form report
REPORT_MAX_TOKENS=6000

# === Search Engine / Retriever ===
# RETRIEVER: "tavily" (1000 free searches/month) | "zai" (free) | "duckduckgo" (free)
# The engine auto-falls back to zai → duckduckgo if Tavily fails.
RETRIEVER=tavily

# Tavily API key (free tier: 1000 searches/month)
# Get your key from: https://tavily.com/
TAVILY_API_KEY=

# Enable fallback chain: if Tavily fails, try Z.AI (free), then DuckDuckGo (free).
SEARCH_FALLBACK_ENABLED=true
