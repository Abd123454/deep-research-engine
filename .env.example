# Deep Research Engine — Environment Configuration
#
# Multi-provider LLM support: NVIDIA (free), OpenAI, Anthropic, Ollama (local).
# Set LLM_PROVIDER=auto (default) to try each in order, or explicitly set one.

# === LLM Provider Selection ===
# "auto" (default) = try NVIDIA → OpenAI → Anthropic → Ollama
# "nvidia" | "openai" | "anthropic" | "ollama" = use only that provider
LLM_PROVIDER=auto

# === NVIDIA NIM API (free) ===
# Get your FREE key from: https://build.nvidia.com/
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# SMART_LLM — for analysis and report writing.
# Strongest models on NVIDIA NIM:
#   meta/llama-3.1-70b-instruct (recommended)
#   nvidia/llama-3.1-nemotron-70b-instruct
#   mistralai/mistral-large-3-675b-instruct-2512
SMART_LLM=meta/llama-3.1-70b-instruct

# FAST_LLM — for sub-questions and quick tasks.
FAST_LLM=meta/llama-3.1-8b-instruct

# SMART_LLM_MODELS — fallback chain (comma-separated).
# If the first fails, the next is tried.
SMART_LLM_MODELS=meta/llama-3.1-70b-instruct,mistralai/mistral-nemotron,mistralai/mistral-small-4-119b-2603,minimaxai/minimax-m3,deepseek-ai/deepseek-v4-pro,mistralai/mistral-large-3-675b-instruct-2512

# === Research Engine Settings ===
SEARCH_DEPTH=advanced
NUM_SUB_QUERIES=7
MAX_LINKS_PER_QUERY=15
NUM_GAP_QUERIES=3
PAGE_READ_CONCURRENCY=4
REPORT_MAX_TOKENS=8000

# === Auth (optional) ===
# Set both to enable HTTP Basic Auth.
AUTH_USERNAME=
AUTH_PASSWORD=

# === Database ===
# For production: PostgreSQL with pgvector
# DATABASE_URL=postgresql://user:pass@localhost:5432/deepresearch
#
# For development: SQLite (no Postgres needed)
# Leave DATABASE_URL empty or set to file:./data/research.db
# DATABASE_URL=file:./data/research.db

# === Document Upload Limit ===
MAX_DOCUMENT_SIZE_MB=50

# === OpenAI API (optional — for multi-provider fallback) ===
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODELS=gpt-4o,gpt-4o-mini
# OPENAI_FAST_MODEL=gpt-4o-mini

# === Anthropic API (optional — for multi-provider fallback) ===
# Get your key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODELS=claude-3-5-sonnet-20241022,claude-3-5-haiku-20241022
# ANTHROPIC_FAST_MODEL=claude-3-5-haiku-20241022

# === Ollama (optional — local, free, no API key) ===
# Install Ollama: https://ollama.com
# Set URL to your Ollama server (default: localhost:11434)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODELS=llama3.1:70b,llama3.1:8b,qwen2.5:7b
# OLLAMA_FAST_MODEL=llama3.1:8b

# === Embedding Models (for memory system) ===
# NVIDIA_EMBED_MODEL=nvidia/nv-embed-v1
# OPENAI_EMBED_MODEL=text-embedding-3-small

# === Security ===
# ALLOWED_ORIGINS — comma-separated list of allowed CORS origins (default: same-origin only)
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ADMIN_IP_ALLOWLIST — comma-separated IPs/CIDRs allowed to reach
# /api/mcp and /api/audit-logs (in addition to auth). When unset,
# these routes only require authentication (their existing behavior).
# Example: ADMIN_IP_ALLOWLIST=10.0.0.0/8,192.168.1.50
# ADMIN_IP_ALLOWLIST=

# NEXTAUTH_SECRET — required for production auth (generate with: openssl rand -base64 32)
# NEXTAUTH_SECRET=

# === Redis (optional — for distributed rate limiting) ===
# REDIS_URL=redis://localhost:6379

# === Tavily Search API (optional — better search results) ===
# TAVILY_API_KEY=

# === Search Fallback ===
# SEARCH_FALLBACK_ENABLED=true
# RETRIEVER=duckduckgo

# === Email service (Resend) ===
# Get your API key from: https://resend.com/api-keys
# RESEND_API_KEY=
# EMAIL_FROM=Quaesitor <noreply@example.com>

# === App URL (used in email links) ===
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Code Execution Sandbox ===
# SECURITY: Code execution is DISABLED by default in BOTH dev and production.
# The vm sandbox fallback is NOT a security boundary (see SECURITY.md and
# the header of src/lib/code-sandbox.ts). Set ENABLE_CODE_EXEC=true ONLY
# after reviewing the threat model and (ideally) wiring up Docker isolation
# via src/lib/code-sandbox-docker.ts. When unset, /api/chat agent run_code
# tool calls and the eval runner's coding tests will return a clear
# disabled-error instead of executing user code.
# ENABLE_CODE_EXEC=true

# === Cloud storage (AWS S3 or Cloudflare R2 — R2 recommended, no egress fees) ===
# When S3_ACCESS_KEY_ID is set, generated files (PDF/DOCX/PPTX/XLSX/MD) are
# uploaded to the bucket and served via presigned download URLs. When unset,
# the app uses a local in-process fallback (suitable for dev only).
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=quaesitor-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
