// Quaesitor — 5-Layer Memory System Schema
//
// Layer 1: Conversation Memory (conversations + messages)
// Layer 2: Long-term Memory (long_term_memories)
// Layer 3: Research History (research_jobs)
// Layer 4: Document Memory (documents)
// Layer 5: User Preferences (user_preferences)
//
// NOTE: This schema supports Postgres for production. For development
// without Postgres, the app falls back to SQLite via better-sqlite3.
// Semantic search uses LIKE on content (text-based), not pgvector.
// This is sufficient for SQLite/single-user use; upgrade to Postgres
// for production scale. See src/lib/db.ts for the fallback logic.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ User ============

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations Conversation[]
  researchJobs  ResearchJobRecord[]
  documents     DocumentRecord[]
  preferences   UserPreference?
  memories      LongTermMemory[]
  projects      Project[]
  subscriptions Subscription[]
  usageRecords  UsageRecord[]

  @@map("users")
}

// ============ Projects / Workspaces ============

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  researchJobs  ResearchJobRecord[]
  documents     DocumentRecord[]
  connectors    Connector[]

  @@index([userId])
  @@map("projects")
}

model Connector {
  id          String   @id @default(cuid())
  projectId   String
  type        String // "github" | "googledrive" | "notion"
  credentials String? // encrypted token (JSON string)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("connectors")
}

// ============ Layer 1: Conversation Memory ============

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  title     String   @default("New Conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([userId])
  @@index([projectId])
  @@map("conversations")
}

model Message {
  id             String                       @id @default(cuid())
  conversationId String
  role           String // "user" | "assistant" | "system"
  content        String
  tokensUsed     Int                          @default(0)
  modelUsed      String?
  // pgvector-backed semantic embedding for this message. Prisma can't
  // natively represent the `vector` type, so we declare it as
  // `Unsupported` — Prisma will skip it in queries, but the column
  // exists at the DB level. The column is added lazily by
  // `src/lib/pgvector-migration.ts` (run on first memory-recall use
  // when Postgres is configured). SQLite has no equivalent column —
  // recall falls back to LIKE search on `content` (see
  // `src/lib/memory-recall.ts`).
  //
  // pgvector requires Postgres + `CREATE EXTENSION vector`.
  embedding      Unsupported("vector(1536)")?
  createdAt      DateTime                     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// ============ Layer 2: Long-term Memory ============

model LongTermMemory {
  id           String                       @id @default(cuid())
  userId       String
  type         String // "fact" | "preference" | "context"
  content      String
  // pgvector-backed semantic embedding for this memory. Same notes as
  // `Message.embedding` — see above. Used by `recallRelevantMemories`
  // for cosine-similarity search (`embedding <=> $query::vector`).
  //
  // pgvector requires Postgres + `CREATE EXTENSION vector`.
  embedding    Unsupported("vector(1536)")?
  confidence   Float                        @default(0.5)
  createdAt    DateTime                     @default(now())
  lastAccessed DateTime?
  accessCount  Int                          @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("long_term_memories")
}

// ============ Layer 3: Research History ============

model ResearchJobRecord {
  id                 String   @id @default(cuid())
  userId             String
  projectId          String?
  query              String
  plan               Json?
  report             String?
  sources            Json?
  stats              Json?
  verificationReport Json?
  status             String   @default("queued")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([projectId])
  @@map("research_jobs")
}

// ============ Layer 4: Document Memory ============

model DocumentRecord {
  id         String                       @id @default(cuid())
  userId     String
  projectId  String?
  filename   String
  mimeType   String
  size       Int
  text       String
  textLength Int
  // pgvector-backed semantic embedding for this document (used for
  // document-QA retrieval). Same notes as `Message.embedding` — see
  // above.
  //
  // pgvector requires Postgres + `CREATE EXTENSION vector`.
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@map("documents")
}

// ============ Layer 5: User Preferences ============

model UserPreference {
  userId            String  @id
  preferredLanguage String? @default("auto")
  preferredDepth    String? @default("standard")
  preferredFormat   String? @default("markdown")
  preferredProvider String? @default("auto")
  timezone          String?

  user User @relation(fields: [userId], references: [id])

  @@map("user_preferences")
}

// ============ Billing ============

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 String    @default("free")
  status               String    @default("active")
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model UsageRecord {
  id         String   @id @default(cuid())
  userId     String
  type       String
  count      Int      @default(1)
  tokensUsed Int      @default(0)
  period     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, period])
  @@index([userId, period])
  @@map("usage_records")
}

// ============ RBAC / Workspace membership ============
// (v5 audit fix #6 — schema drift: these 7 tables existed only as raw
//  SQLite DDL / ad-hoc Postgres ALTER statements and were missing from
//  the canonical Prisma schema. Adding them brings the schema in sync
//  with the runtime so `prisma db push` and `prisma migrate` produce a
//  database that matches what the application code expects.)

/// Workspace (project) membership. Many-to-many between User and
/// Project with a per-membership role (owner / admin / editor /
/// viewer). The @@unique constraint enforces one membership row per
/// (user, project) pair — `role` is mutated, never duplicated.
model WorkspaceMember {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  role      String   @default("viewer")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@map("workspace_members")
}

/// Developer-platform API keys. The `keyHash` is SHA-256 of the raw
/// `qaesitor_...` token; the raw token is shown to the caller exactly
/// once at creation time. `keyPrefix` is the first ~10 chars (for
/// display in the dashboard so the user can identify which key is
/// which). `expiresAt` is optional — null means "no expiry".
model ApiKey {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  name       String
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")

  @@index([userId])
  @@map("api_keys")
}

/// GDPR Art. 7 — demonstrable consent ledger. Each row records a
/// single grant/revoke of a consent key (termsOfService,
/// privacyPolicy, memoryExtraction, marketing, ageConfirmation).
/// `grantedAt` and `revokedAt` together form the consent timeline;
/// the latest non-null timestamp wins. The @@unique constraint
/// enforces one row per (user, consentKey) — updates mutate, never
/// duplicate.
model ConsentLedger {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  consentKey String    @map("consent_key")
  granted    Boolean
  grantedAt  DateTime  @default(now()) @map("granted_at")
  revokedAt  DateTime? @map("revoked_at")

  @@unique([userId, consentKey])
  @@map("consent_ledger")
}

/// Per-user MFA secret (TOTP). One row per user — the primary key IS
/// the userId. `backupCodes` is a JSON-encoded array of bcrypt hashes
/// (the plaintext backup codes are shown to the user once at setup
/// time, never stored). `enabled` distinguishes "secret provisioned
/// but not yet confirmed" (false) from "actively enforcing MFA"
/// (true) — only `enabled=true` rows grant access.
model UserMfa {
  userId      String  @id @map("user_id")
  mfaSecret   String  @map("mfa_secret")
  backupCodes String? @map("backup_codes")
  enabled     Boolean @default(false)

  @@map("user_mfa")
}

/// Single-use verification tokens (email verification + password
/// reset). `type` is `email_verification` or `password_reset`.
/// `expiresAt` is 1h after creation. `usedAt` is null until
/// consumed — a non-null `usedAt` means the token is spent and MUST
/// NOT be accepted again (single-use semantics).
model VerificationToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  type      String
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("verification_tokens")
}

/// Memory-graph edges — weighted relationships between long-term
/// memories (e.g. "fact A contradicts fact B" or "context C
/// supports fact D"). `weight` is in [-1, 1]; positive = support,
/// negative = contradiction. Used by the memory-recall pipeline to
/// surface corroborating + conflicting memories alongside a recall
/// hit, so the model can flag contradictions in its synthesis.
model MemoryEdge {
  id             String   @id @default(cuid())
  sourceMemoryId String   @map("source_memory_id")
  targetMemoryId String   @map("target_memory_id")
  relationType   String   @map("relation_type")
  weight         Float
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([sourceMemoryId])
  @@index([targetMemoryId])
  @@map("memory_edges")
}

/// Security audit log — distinct from the operational `audit_logs`
/// table. This table records security-significant events (failed
/// logins, MFA challenges, CSRF rejections, rate-limit hits,
/// admin-access denials) for compliance reporting (SOC 2, GDPR
/// Art. 30 ROPA). `severity` is `info` / `warn` / `critical`.
/// `metadata` is a JSON blob with event-specific context (the
/// failed password hash, the rate-limit bucket state, etc.) —
/// sensitive fields (raw passwords, raw tokens) are NEVER stored.
model SecurityAuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  event     String
  severity  String   @default("info")
  ip        String?
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("security_audit_log")
}
