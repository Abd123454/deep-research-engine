{
  "name": "quaesitor-desktop",
  "version": "1.0.0",
  "description": "Quaesitor — Electron desktop wrapper for the self-hosted AI workstation.",
  "main": "main.js",
  "author": "Quaesitor",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.quaesitor.desktop",
    "productName": "Quaesitor",
    "copyright": "Copyright © 2024 Quaesitor",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "tray-icon.png",
      "icon.png",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "snap"
      ],
      "icon": "icon.png",
      "category": "Office",
      "maintainer": "Quaesitor",
      "desktop": {
        "Name": "Quaesitor",
        "Comment": "Quaesitor Desktop App",
        "Categories": "Office;Research;Utility;",
        "Terminal": "false",
        "Type": "Application"
      }
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Quaesitor"
    }
  }
}
