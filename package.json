{
  "name": "quaesitor",
  "version": "4.0.0",
  "private": true,
  "author": "Abd",
  "license": "AGPL-3.0",
  "description": "Quaesitor — Self-hosted AI Workstation with deep research, agent swarm, code execution, vision, and voice.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval": "bun run scripts/eval.ts",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "worker": "bun run worker.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-collapsible": "^1.1.17",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-progress": "^1.1.13",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-separator": "^1.1.12",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.4",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-toast": "^1.2.20",
    "@radix-ui/react-toggle-group": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@react-email/components": "^1.0.12",
    "@sentry/nextjs": "^10.66.0",
    "@stripe/stripe-js": "^9.10.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "bullmq": "^5.80.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "dompurify": "^3.4.12",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.42.2",
    "ioredis": "^5.11.1",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.525.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.16.0",
    "next": "^16.2.10",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "posthog-js": "^1.404.1",
    "posthog-node": "^5.45.2",
    "pptxgenjs": "^4.0.1",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.9.0",
    "react-markdown": "^10.1.0",
    "resend": "^6.17.2",
    "sonner": "^2.0.7",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
